# Fill all ALIAS_* values before running in production

APP_ENV=dev
APP_NAME=ALIAS_APP_NAME
APP_LOG_LEVEL=INFO
APP_TIMEZONE=Asia/Ho_Chi_Minh

TELEGRAM_BOT_TOKEN=ALIAS_TELEGRAM_BOT_TOKEN
TELEGRAM_WEBHOOK_SECRET=ALIAS_TELEGRAM_WEBHOOK_SECRET
TELEGRAM_PUBLIC_BASE_URL=ALIAS_TELEGRAM_PUBLIC_BASE_URL
TELEGRAM_USE_WEBHOOK=true

ADMIN_API_KEY=ALIAS_ADMIN_API_KEY

SQLITE_DB_PATH=ALIAS_SQLITE_DB_PATH
CARDS_JSON_PATH=ALIAS_CARDS_JSON_PATH
ASSETS_BASE_DIR=ALIAS_ASSETS_BASE_DIR

SCHEDULE_MORNING=09:00
SCHEDULE_NOON=13:00
SCHEDULE_EVENING=20:30

DEFAULT_NEW_PER_DAY=10
DEFAULT_REVIEW_LIMIT=50
LEECH_THRESHOLD=5

# Gemini AI Configuration
GEMINI_API_KEY=ALIAS_GEMINI_API_KEY
GEMINI_MODEL=gemini-3.1-flash-lite-preview
